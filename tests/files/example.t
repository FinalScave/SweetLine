包名 示例.高亮

@组件配置({宽度=-1, 高度=-1, 根布局=真, 说明=[[启动窗口 "主界面"
支持长文本注解参数]]})
类 启动窗口<T = 文本, U = 集合<整数>> : 窗口<文本, 集合<整数>>

	@组件配置({宽度=-1, 高度=-1, 纵向布局=真})
	变量 根布局: 线性布局

	@组件配置({内容="显示", $权重=1}, 父布局=根布局)
	变量 显示按钮: 按钮

	@组件配置({内容="关闭", $权重=1}, 父布局=根布局)
	变量 关闭按钮: 按钮

	变量 数据列表: 集合<文本>
	变量 数据表: 哈希表<文本, 集合<整数[]>>
	变量 固定数字: 整数[10]
	变量 可空标题: 文本? = 空
	变量 当前状态: 整数 = 0
	常量 默认扩展类型 为 整数 = 0X10
	常量 服务地址 为 文本 = "https://example.com/api"

	定义事件 数据已加载(来源: 对象, 列表: 集合<文本>): 逻辑型
	定义事件 状态被改变(旧值 为 整数, 新值 为 整数)

	事件 启动窗口:创建完毕()
		订阅事件()
		变量 对话框1: 对话框 = 创建 对话框
		变量 临时表: 哈希表<文本, 集合<整数[]>> = 创建 哈希表<文本, 集合<整数[]>>()
		变量 固定列表: 整数[默认扩展类型]
		变量 内容: 文本 = [[
多行文本可以包含网址 https://example.com/help
也可以保留 #this 这类嵌入式标记文字
]]
		如果 可空标题 == 空 则
			可空标题 = "启动完成"
		否则 当前状态 > 0
			弹出提示("状态已存在")
		否则
			当前状态 = 1
		结束 如果

		假如 当前状态
		是 0
			弹出提示("空状态")
		是 1, 2
			弹出提示("运行中")
		否则
			弹出提示("未知状态")
		结束 假如

		循环(i, 0, 10)
			固定数字[i] = i
		结束 循环

		循环(数据列表 -> 项)
			调试输出(项)
		结束 循环

		code #this->GetData(#cls<文本>, #ncls<窗口>, #mem<根布局.取根布局()>, #expr<当前状态 + 1>, #sys<line>);
		@code(header)
		private String title = #可空标题;
		private int count = #expr<当前状态 + 1>;
		@end
	结束 事件

	事件 显示按钮:被单击()
		变量 对话框1: 对话框
		对话框1.内容 = 可空标题
		对话框1.显示()

		事件 对话框1:按钮1被单击()
			弹出提示("对话框按钮被单击")
			对话框1.关闭()
		结束 事件
	结束 事件

	事件 根布局.显示按钮:被长按()
		如果 当前状态 属于 整数 则
			返回
		结束 如果
	结束 事件

	@运算符重载
	方法 =(初始值: 文本): 启动窗口<文本, 集合<整数>>
		可空标题 = 初始值
		返回 本对象
	结束 方法

	@运算符重载
	方法 +(追加对象: 对象): 集合<文本>
		变量 结果: 集合<文本> = 创建 集合<文本>()
		返回 结果
	结束 方法

	@运算符重载
	方法 ==(另一个: 启动窗口<文本, 集合<整数>>): 逻辑型
		如果 另一个 == 空 则
			返回 假
		结束 如果
		返回 真
	结束 方法

	@运算符重载
	方法 [](索引: 整数): 文本
		返回 数据列表[索引]
	结束 方法

	@运算符重载
	方法 []=(索引: 整数, 值: 文本)
		数据列表[索引] = 值
	结束 方法

	属性读 标题(): 文本
		返回 可空标题
	结束 属性

	属性写 标题(值: 文本)
		可空标题 = 值
	结束 属性

	方法 设置扩展(
		样式: 对象,
		开始位置: 整数,
		结束位置: 整数,
		扩展类型: 整数 = 默认扩展类型
	): 集合<文本>
		变量 结果: 集合<文本> = 创建 集合<文本>()
		返回 结果
	结束 方法

	方法 读入对象(路径 为 文本) 为 对象
		@code
		try {
			return readObject(#路径);
		} catch (Exception e) {
			return null;
		}
		@end
	结束 方法

	/*
	块注释里也保留 URL: https://example.com/comment
	*/
	方法 处理状态(状态: 整数): 文本
		如果 状态 == 0 或 状态 == 1 则
			返回 "ok"
		结束 如果
		返回 "other"
	结束 方法

结束 类

类 数据项<T = 文本>
	变量 名称: T
	变量 标签: 集合<文本>

	方法 复制(): 数据项<T>
		变量 结果: 数据项<T> = 创建 数据项<T>()
		结果.名称 = 名称
		返回 结果
	结束 方法
结束 类
