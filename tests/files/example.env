# SweetLine environment sample
# Docs: https://example.com/env/reference
APP_NAME=SweetLine
APP_ENV=staging
APP_VERSION=2.4.7
APP_BUILD=20260416
APP_DOCS_URL=https://docs.example.com/sweetline?lang=en&ref=env
APP_ASSET_CDN=https://cdn.example.com/assets/v2
APP_STATUS_PAGE=https://status.example.com/incidents/latest
APP_SUPPORT_EMAIL=support@example.com
APP_SUPPORT_PORTAL=https://help.example.com/tickets/new
APP_PUBLIC_ORIGIN=https://demo.example.com
APP_PUBLIC_API=https://api.example.com/v1
APP_PUBLIC_WS=wss://stream.example.com/realtime
APP_PUBLIC_SENTRY=https://public@example.ingest.sentry.io/42
APP_REGION=ap-southeast-1
APP_TIMEZONE=Asia/Shanghai
APP_DEFAULT_LOCALE=en_US
APP_FALLBACK_LOCALE=zh_CN
APP_THEME=night-sky
APP_PRIMARY_COLOR="#0f5bd8"
APP_ACCENT_COLOR="#ff8a00"
APP_FEATURE_INLINE_STYLE=true
APP_FEATURE_URL_LINKING=true
APP_FEATURE_DIFF_VIEW=true
APP_FEATURE_EXPERIMENTAL=false
APP_RELEASE_CHANNEL=beta
APP_STARTUP_TIMEOUT_MS=1500
APP_IDLE_TIMEOUT_MS=30000
APP_MAX_RETRIES=5
APP_BACKOFF_RATIO=1.75
APP_CACHE_TTL_SECONDS=86400
APP_CACHE_PREFIX=sweetline:demo
APP_LOG_LEVEL=debug
APP_LOG_FILE=/var/log/sweetline/app.log
APP_LOG_FORMAT=json
APP_TRACE_ID_HEADER=X-Trace-Id
APP_REQUEST_ID_HEADER=X-Request-Id
APP_ALLOWED_HOSTS=demo.example.com,localhost,127.0.0.1
APP_ALLOWED_ORIGINS=https://demo.example.com,https://preview.example.com
APP_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE
APP_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-Id
APP_CSP_DEFAULT_SRC="'self' https://cdn.example.com"
APP_CSP_IMG_SRC="'self' data: https://images.example.com"
APP_CSP_CONNECT_SRC="'self' https://api.example.com wss://stream.example.com"
APP_HEALTHCHECK_PATH=/internal/healthz
APP_METRICS_PATH=/internal/metrics
APP_GRAPHQL_PATH=/graphql
APP_REWRITE_RULE=^/docs/(.*)$:/guide/$1
APP_SSH_BASTION=ops@example.com:2222
APP_KAFKA_BROKERS=broker-1:9092,broker-2:9092,broker-3:9092
APP_REDIS_URL=redis://cache.example.com:6379/4
APP_DATABASE_URL=postgres://demo:secret@db.example.com:5432/sweetline
APP_AMQP_URL=amqps://mq.example.com/%2fsweetline
APP_OBJECT_STORAGE=s3://sweetline-assets/releases/2026-04-16/
APP_OBJECT_STORAGE_REGION=us-west-2
APP_UPLOAD_TMP_DIR=/tmp/sweetline/uploads
APP_NODE_OPTIONS=--trace-warnings --max-old-space-size=1024
APP_JAVA_OPTS=-Xms256m -Xmx768m -Dfile.encoding=UTF-8
APP_PROXY_HTTP=http://proxy.internal.example.com:8080
APP_PROXY_HTTPS=http://proxy.internal.example.com:8443
APP_PROXY_NO=localhost,127.0.0.1,.example.internal
APP_SIGNING_KEY_ID=primary-demo-key
APP_SIGNING_ALG=RS256
APP_TOKEN_AUDIENCE=sweetline-demo
APP_TOKEN_ISSUER=https://auth.example.com/
APP_AUTH_WELL_KNOWN=https://auth.example.com/.well-known/openid-configuration
APP_ANALYTICS_WRITE_KEY=write_live_abc123
APP_CRASH_SAMPLE_RATE=0.05
APP_PROFILING_SAMPLE_RATE=0.10
APP_MAINTENANCE_WINDOW=Sun 02:00-04:00 UTC
APP_DEPLOY_SHA=9f6d7c1ab45f92d0beefcafe
APP_DEPLOY_TAG=v2.4.7-beta.3
APP_DEPLOY_MESSAGE="Deploy build ${APP_BUILD} from ${APP_DEPLOY_SHA}"
APP_WELCOME_MESSAGE="Visit ${APP_DOCS_URL} for the latest setup guide"
APP_FOOTER_TEXT='Need help? Open https://help.example.com'
APP_JSON_BLOB="{\"theme\":\"night-sky\",\"inlineStyle\":true}"
APP_ESCAPED_EQUALS=alpha\=beta
APP_ESCAPED_HASH=literal\#fragment
APP_ESCAPED_DOLLAR=cost\$99
APP_ESCAPED_SPACE=hello\ world
APP_ESCAPED_BACKSLASH=C:\\Tools\\SweetLine
APP_ESCAPED_QUOTE=\"quoted\"
APP_ESCAPED_SINGLE=\'single\'
APP_PATH_POSIX=/opt/sweetline/current/bin
APP_PATH_WINDOWS=C:\Program Files\SweetLine\bin
APP_CERT_FILE=/etc/ssl/certs/sweetline.pem
APP_CERT_CHAIN=/etc/ssl/certs/sweetline-chain.pem
APP_CERT_FINGERPRINT=4A:7B:9F:12:6D:C2:11:80:AA:0B:CC:DD:EF:10:22:33
APP_RATE_LIMIT_BURST=120
APP_RATE_LIMIT_SUSTAINED=60
APP_CACHE_SHARDS=16
APP_SEGMENT_BATCH_SIZE=500
APP_SEGMENT_FLUSH_INTERVAL_MS=2000
APP_MESSAGE_TEMPLATE="Hello ${USER_NAME:-guest}, open ${APP_SUPPORT_PORTAL}"
APP_DOCKER_IMAGE=registry.example.com/sweetline/demo:2.4.7
APP_HELM_CHART=oci://registry.example.com/charts/sweetline
APP_HELM_VERSION=1.9.3
APP_K8S_NAMESPACE=sweetline-demo
APP_K8S_SERVICE_ACCOUNT=sweetline-runtime
APP_TLS_MIN_VERSION=TLSv1.2
APP_TLS_CIPHERS=TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384
APP_IPV4_BIND=0.0.0.0
APP_IPV6_BIND=::1
APP_HTTP_PORT=8080
APP_HTTPS_PORT=8443
APP_GRPC_PORT=9090
APP_OTLP_ENDPOINT=https://otel.example.com:4318
APP_OTLP_HEADERS=Authorization=Bearer\ secret-token
APP_QUEUE_NAME=events.primary
APP_QUEUE_DLQ=events.primary.dlq
APP_TOPIC_AUDIT=audit.events.v1
APP_TOPIC_USAGE=usage.metrics.v2
APP_FLAG_ROLLOUT_SEARCH=25
APP_FLAG_ROLLOUT_SHARE=100
APP_FLAG_ROLLOUT_IMPORT=0
APP_ADMIN_USERS=alice,bob,carol,dave
APP_SEED_PROJECTS=alpha,beta,gamma
APP_LANGUAGE_PACKS=en_US,zh_CN,ja_JP,de_DE
APP_BANNER_TEXT="Preview mode enabled until 2026-05-01"
APP_NOTICE_MD="[Changelog](https://example.com/changelog) and `tips`"
APP_LAST_SYNC=2026-04-16T10:32:18Z
APP_NEXT_SYNC=2026-04-16T10:37:18Z
APP_ROTATION_CRON=0 */6 * * *
APP_ENABLE_AUDIT_LOGS=yes
APP_ENABLE_REPLAY_MODE=no
APP_ENABLE_VERBOSE_SQL=false
APP_FINAL_SENTINEL=env-sample-complete
