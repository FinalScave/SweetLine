# Ignore build artifacts and cache files.
# Docs: https://git-scm.com/docs/gitignore
/build/
/dist/
/tmp/
/coverage/
/reports/
/generated/
/vendor/
/artifacts/
/logs/
/public/build/
/public/assets/
/android/.gradle/
/ios/DerivedData/
/windows/.dart_tool/
/macos/Pods/
