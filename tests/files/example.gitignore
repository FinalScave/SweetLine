*.tfstate.*
*.pem
*.key
*.crt
*.mobileprovision
*.jks
*.keystore
**/node_modules/
**/coverage/
**/.cache/
**/.sass-cache/
**/.terraform/
**/.venv/
**/__pycache__/
**/.DS_Store
**/Thumbs.db
**/.idea/
**/.vscode/
**/.fleet/
cache/**/
cache/**/tmp/
cache/**/snapshots/
cache/**/index-??.json
cache/**/[0-9][0-9][0-9][0-9]/
assets/[A-Za-z]*/sprite-??.png
assets/**/atlas-*.json
assets/**/raw/[!a-z]*
assets/**/export/\#temp-*.png
assets/**/drafts/\[review\]-*.svg
docs/**/[!a-z]*
docs/**/generated/
docs/**/preview-??.html
docs/**/images/*-draft.png
docs/**/images/*-copy?.png
docs/archive/20[0-9][0-9]/
docs/archive/**/[0-9][0-9]-notes.md
config/\#literal.txt
config/\!important.txt
config/\[sample\].ini
config/\{template\}.json
config/space\ name.txt
images/\[draft\].png
images/\!keep/me.png
images/raw/\#contact-sheet.jpg
notes/space\ name.txt
notes/\!urgent.md
notes/\#backlog.md
scripts/*.local.sh
scripts/**/*.secret.sh
secrets/**/*
keys/**/*.pub
keys/**/*.pem
terraform/.terraform.lock.hcl
terraform/*.tfvars
terraform/*.tfplan
helm/**/Chart.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.env
.env.*
!.env.example
!.env.development.sample
!.env.production.template
!.github/
!.github/workflows/
!.github/ISSUE_TEMPLATE/
!/dist/keep.txt
!/dist/templates/
!/dist/templates/README.md
!/docs/reference/
!/docs/reference/index.md
!/public/assets/.keep
!/public/assets/icons/
!/public/assets/icons/logo.svg
!/scripts/bootstrap.local.sh
!/config/\#literal.txt
!/images/\[draft\].png
!/notes/\!urgent.md
!/terraform/examples/
!/terraform/examples/dev.tfvars
!/helm/base/Chart.lock.example
