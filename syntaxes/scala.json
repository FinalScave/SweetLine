{
  "name": "scala",
  "fileExtensions": [".scala", ".sc", ".sbt"],
  "variables": {
    "identifier": "(?:`[^`]+`|[A-Za-z_][A-Za-z0-9_$]*)",
    "typeIdentifier": "(?:`[^`]+`|[A-Z][A-Za-z0-9_$]*)",
    "qualifiedId": "${identifier}(?:\\.${identifier})*",
    "qualifiedTypeId": "(?:(?:${identifier})\\.)*${typeIdentifier}(?:\\.${typeIdentifier})*",
    "methodName": "(?:`[^`]+`|[A-Za-z_][A-Za-z0-9_$]*|[+\\-*/%&|^!~:?<>#=\\\\]+)",
    "whiteSpace": "[ \\t\\f]",
    "any": "[\\S\\s]"
