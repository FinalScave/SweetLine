<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>SweetLine</PackageId>
		<Title>SweetLine</Title>
		<Authors>Scave</Authors>
		<Company>Mobie-IPE</Company>
		<Product>SweetLine</Product>
		<PackageProjectUrl>https://github.com/FinalScave/SweetLine</PackageProjectUrl>
		<RepositoryUrl>https://github.com/FinalScave/SweetLine</RepositoryUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<AssemblyName>$(MSBuildProjectName).Net</AssemblyName>
		<Version>1.1.0</Version>
	</PropertyGroup>

	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="" />
		<Content Include="..\..\..\cmake-build-release-visual-studio\bin\sweetline.dll" Pack="true" PackagePath="runtimes\win-x64\native\">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>
</Project>
