  "description": "基于C++17跨平台语法高亮引擎SweetLine的ArkTS绑定，支持语法高亮（全量分析+增量分析双支持）、作用域划线分析等特性",
  "main": "./src/main/ets/Index.ets",
  "types": "./src/main/ets/Index.d.ts",
  "author": "Scave",
  "license": "LGPL-2.1-or-later",
  "keywords": ["富文本", "代码高亮", "高亮", "rich text", "highlight"],
  "homepage": "https://github.com/FinalScave/SweetLine",
  "repository": "https://github.com/FinalScave/SweetLine",
  "dependencies": {
    "libsweetline.so": "file:./src/main/cpp/types/libsweetline"
  }
}
